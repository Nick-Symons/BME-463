Basic idea:
A clean ECG has a highly repeatable morphology — each beat looks almost identical to the previous one. A noisy signal doesn't. You can exploit this by:

Extract a template from the first few detected beats (average of beats 2-5 to avoid startup transients)
For each subsequent beat, compute the cross-correlation between that beat's waveform and the template
Average the correlation coefficient over the recording — clean signals will have high correlation (>0.8), noisy signals will have low correlation (<0.5)
*/

double computeBeatCorrelation(const vector<double>& signal,
                               const vector<int>&    timestamps,
                               int                   beatWindowSamples = 200) {
    if (timestamps.size() < 5) return 0.0;

    // Build template from beats 2-4
    vector<double> templateBeat(beatWindowSamples, 0.0);
    int templateCount = 0;
    for (int i = 1; i <= 3 && i < (int)timestamps.size(); i++) {
        int start = timestamps[i] - beatWindowSamples / 2;
        if (start < 0 || start + beatWindowSamples >= (int)signal.size())
            continue;
        for (int j = 0; j < beatWindowSamples; j++)
            templateBeat[j] += signal[start + j];
        templateCount++;
    }
    if (templateCount == 0) return 0.0;
    for (double& v : templateBeat) v /= templateCount;

    // Correlate each subsequent beat against template
    double totalCorr = 0.0;
    int    corrCount = 0;

    for (int i = 4; i < (int)timestamps.size(); i++) {
        int start = timestamps[i] - beatWindowSamples / 2;
        if (start < 0 || start + beatWindowSamples >= (int)signal.size())
            continue;

        // Pearson correlation
        double meanT = 0.0, meanB = 0.0;
        for (int j = 0; j < beatWindowSamples; j++) {
            meanT += templateBeat[j];
            meanB += signal[start + j];
        }
        meanT /= beatWindowSamples;
        meanB /= beatWindowSamples;

        double num = 0.0, denT = 0.0, denB = 0.0;
        for (int j = 0; j < beatWindowSamples; j++) {
            double dt = templateBeat[j] - meanT;
            double db = signal[start + j] - meanB;
            num  += dt * db;
            denT += dt * dt;
            denB += db * db;
        }
        double corr = (denT > 0 && denB > 0) ? num / sqrt(denT * denB) : 0.0;
        totalCorr  += corr;
        corrCount++;
    }
    return (corrCount > 0) ? totalCorr / corrCount : 0.0;
}
